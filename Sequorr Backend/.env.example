# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/sequorr

# Admin API key — set a strong secret
ADMIN_API_KEY=changeme_supersecretkey123

# RunSignUp API (Findr — race discovery)
RUNSIGNUP_API_KEY=your_key_here
RUNSIGNUP_API_SECRET=your_secret_here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://findr.app

# Email (Nodemailer SMTP) — waitlist welcome emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@sequorr.com
